# Server
SERVER_PORT=3001
CLIENT_URL=http://localhost:3000

# Client (prefix with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# Lyrics (optional — Name That Lyric mode uses lyrics.ovh by default, free and no key needed)
# Add a Musixmatch API key here for a higher-quality fallback when lyrics.ovh can't find a song
# MUSIXMATCH_API_KEY=your_key_here
